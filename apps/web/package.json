    "pretest:e2e": "VITE_E2E=1 vite build",
    "test:e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "@ganttly/calendar-data": "workspace:*",
    "@ganttly/gan-parser": "workspace:*",
    "@ganttly/schema": "workspace:*",
    "@radix-ui/react-dialog": "^1.1.21",
    "@radix-ui/react-dropdown-menu": "^2.1.22",
    "@radix-ui/react-popover": "^1.1.21",
    "@radix-ui/react-tooltip": "^1.2.14",
    "clsx": "^2.1.1",
    "date-fns": "^3.6.0",
    "i18next": "^23.12.0",
    "lucide-react": "^1.26.0",
    "nanoid": "^5.0.7",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^15.0.0",
    "react-router-dom": "^7.18.1",
    "tailwind-merge": "^2.4.0",
